# Copy this file to .env and fill in real values before running docker-compose up.
# Never commit the real .env file.

# ---- Ports (change these if they conflict with something else on the mini PC) ----
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ---- Postgres ----
POSTGRES_USER=planit
POSTGRES_PASSWORD=changeme
POSTGRES_DB=planit
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Backend ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# The origin the frontend is served from, as seen by the browser.
# Set this to the mini PC's LAN IP + frontend port once deployed, e.g. http://192.168.1.50:5173
CORS_ORIGIN=http://localhost:5173

# Used once by scripts/seed_superadmin.py to create the first superadmin account.
# Safe to leave set after initial setup — the script is idempotent (no-op if a
# superadmin already exists) — but consider removing/rotating it afterward.
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=changeme123

# ---- Frontend ----
# The base URL the browser uses to reach the backend API.
# Set this to the mini PC's LAN IP + backend port once deployed, e.g. http://192.168.1.50:8000
VITE_API_BASE_URL=http://localhost:8000
